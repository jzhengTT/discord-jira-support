# Discord
DISCORD_BOT_TOKEN=
# The forum channel to watch (right-click channel -> Copy ID, needs Developer Mode)
DISCORD_FORUM_CHANNEL_ID=
# Comma-separated role IDs allowed to trigger tickets (besides the thread author)
DISCORD_TEAM_ROLE_IDS=

# Jira Cloud (Service Management)
JIRA_BASE_URL=https://tenstorrent.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# CUST project service desk; request type 108 = "General Support"
JIRA_SERVICE_DESK_ID=1
JIRA_REQUEST_TYPE_ID=108
JIRA_EXTRA_LABELS=discord-support

# Bot behavior
# Comma-separated unicode emojis that trigger ticket creation
TICKET_EMOJIS=🎫,🎟️
SUPPORT_EMAIL=support@tenstorrent.com
LOG_LEVEL=INFO
